# SmartAid Backend Environment Configuration
# Copy this to .env and fill in your values

# --- Firebase ---
# Path to your downloaded service account key (relative to backend/ folder)
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
GOOGLE_APPLICATION_CREDENTIALS=serviceAccountKey.json

# Set to "false" to bypass JWT token verification during local development
AUTH_REQUIRED=true

# --- Vertex AI (Gemini) "Brain" for dispatch decisions ---
# Requires GCP authentication via Application Default Credentials, e.g.:
# - set GOOGLE_APPLICATION_CREDENTIALS to a service account JSON with Vertex AI permissions
# - or run on GCP (Cloud Run / Compute) with an attached service account
VERTEX_ENABLED=false
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-1.5-flash
# Optional tuning
VERTEX_TEMPERATURE=0.2
VERTEX_MAX_TOKENS=512
